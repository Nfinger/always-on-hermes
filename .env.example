OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Transcription provider (default is fully local/open-source)
STT_PROVIDER=whisper_local
WHISPER_MODEL_SIZE=base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en
WHISPER_MODEL_DIR=

# Menubar companion behavior
AUTO_START_DEFAULT_SESSION=1
AUTO_START_SESSION_TITLE=Always-on session
AUTO_START_SESSION_NOTES=always on assistant, Nate

SYSTEM_PROMPT=You are an interview copilot. Suggest concise, high-signal follow-up questions based on candidate responses and job requirements.

# Notion integration (optional but required for /notion-sync)
NOTION_API_KEY=
NOTION_PARENT_PAGE_ID=
