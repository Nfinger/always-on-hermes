<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.nate.alwaysonhermes.menubar</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/homebase/.hermes/tools/interview-copilot/scripts/run_menubar.sh</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/always-on-hermes-menubar.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/always-on-hermes-menubar.err.log</string>
</dict>
</plist>
